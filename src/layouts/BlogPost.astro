---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, tags } = post.data;

const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const formattedUpdatedDate = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Estimate reading time from body
const words = post.body?.split(/\s+/).length ?? 0;
const readingTime = Math.max(1, Math.round(words / 200));
---

<BaseLayout title={title} description={description} type="article" pubDate={pubDate}>
  <article class="blog-post-wrapper">
    <div class="container">
      <nav class="back-nav" aria-label="Breadcrumb">
        <a href="/blog" class="back-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m15 18-6-6 6-6"/>
          </svg>
          All posts
        </a>
      </nav>

      <header class="post-header">
        {tags.length > 0 && (
          <div class="post-tags" aria-label="Tags">
            {tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>
        <div class="post-meta">
          <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
          <span class="meta-sep" aria-hidden="true">·</span>
          <span>{readingTime} min read</span>
          {updatedDate && (
            <>
              <span class="meta-sep" aria-hidden="true">·</span>
              <span>Updated <time datetime={updatedDate.toISOString()}>{formattedUpdatedDate}</time></span>
            </>
          )}
        </div>
      </header>

      <div class="post-divider" aria-hidden="true"></div>

      <div class="prose post-body">
        <slot />
      </div>

      <div class="post-footer">
        <a href="/blog" class="back-link-bottom">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m15 18-6-6 6-6"/>
          </svg>
          Back to all posts
        </a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post-wrapper {
    background: var(--color-bg);
    min-height: 100svh;
    padding-top: 6rem;
    padding-bottom: 5rem;
    transition: background 0.3s ease;
  }

  .blog-post-wrapper .container {
    max-width: 780px;
  }

  .back-nav {
    margin-bottom: 2.5rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .back-link:hover { color: var(--color-sage); }

  .post-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-sage);
    background: color-mix(in srgb, var(--color-sage) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-sage) 25%, transparent);
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
  }

  .post-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--color-heading);
    margin: 0;
    letter-spacing: -0.03em;
    line-height: 1.2;
  }

  .post-description {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    margin: 0;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    flex-wrap: wrap;
  }

  .meta-sep { opacity: 0.4; }

  .post-divider {
    height: 1px;
    background: var(--color-border);
    margin-bottom: 2.5rem;
  }

  .post-body {
    color: var(--color-text);
    font-size: 1.0625rem;
    line-height: 1.8;
  }

  /* ── Prose paragraphs ── */
  .post-body :global(p) {
    margin-block: 1.25em;
  }

  /* ── Prose headings ── */
  .post-body :global(h2),
  .post-body :global(h3),
  .post-body :global(h4),
  .post-body :global(h5),
  .post-body :global(h6) {
    color: var(--color-heading);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin-top: 2em;
    margin-bottom: 0.5em;
    scroll-margin-top: 5rem;
  }

  .post-body :global(h2) {
    font-size: 1.625rem;
  }

  .post-body :global(h3) {
    font-size: 1.3rem;
  }

  .post-body :global(h4) {
    font-size: 1.125rem;
    letter-spacing: -0.01em;
  }

  .post-body :global(h5) {
    font-size: 1rem;
    letter-spacing: 0;
  }

  .post-body :global(h6) {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0;
  }

  .post-body :global(a) {
    color: var(--color-sage);
    text-decoration-color: var(--color-sage);
  }
  .post-body :global(a:hover) {
    color: var(--color-olive);
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--color-sage);
    padding-left: 1.25rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-inline: 0;
  }

  .post-body :global(pre) {
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    overflow-x: auto;
    padding: 1.25rem 1.5rem;
  }

  .post-body :global(code:not(pre code)) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.1rem 0.35rem;
    font-size: 0.875em;
    color: var(--color-sage);
  }

  .post-body :global(img) {
    border-radius: 0.75rem;
    width: 100%;
    height: auto;
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-block: 2.5rem;
  }

  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .back-link-bottom {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .back-link-bottom:hover { color: var(--color-sage); }
</style>
