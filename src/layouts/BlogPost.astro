---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, tags } = post.data;

const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const formattedUpdatedDate = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Estimate reading time from body
const words = post.body?.split(/\s+/).length ?? 0;
const readingTime = Math.max(1, Math.round(words / 200));
---

<BaseLayout title={title} description={description} type="article" pubDate={pubDate}>
  <article class="blog-post-wrapper">
    <div class="container">
      <nav class="back-nav" aria-label="Breadcrumb">
        <a href="/blog" class="back-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m15 18-6-6 6-6"/>
          </svg>
          All posts
        </a>
      </nav>

      <header class="post-header">
        {tags.length > 0 && (
          <div class="post-tags" aria-label="Tags">
            {tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>
        <div class="post-meta">
          <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
          <span class="meta-sep" aria-hidden="true">·</span>
          <span>{readingTime} min read</span>
          {updatedDate && (
            <>
              <span class="meta-sep" aria-hidden="true">·</span>
              <span>Updated <time datetime={updatedDate.toISOString()}>{formattedUpdatedDate}</time></span>
            </>
          )}
        </div>
      </header>

      <div class="post-divider" aria-hidden="true"></div>

      <div class="prose post-body">
        <slot />
      </div>

      <div class="post-footer">
        <a href="/blog" class="back-link-bottom">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m15 18-6-6 6-6"/>
          </svg>
          Back to all posts
        </a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post-wrapper {
    background: var(--color-bg);
    min-height: 100svh;
    padding-top: 6rem;
    padding-bottom: 5rem;
    transition: background 0.3s ease;
  }

  .blog-post-wrapper .container {
    max-width: 860px;
  }

  @media (min-width: 1024px) {
    .blog-post-wrapper .container {
      max-width: 900px;
    }
  }

  .back-nav {
    margin-bottom: 2.5rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .back-link:hover { color: var(--color-sage); }

  .post-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-sage);
    background: color-mix(in srgb, var(--color-sage) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-sage) 25%, transparent);
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
  }

  .post-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--color-heading);
    margin: 0;
    letter-spacing: -0.03em;
    line-height: 1.2;
  }

  .post-description {
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    margin: 0;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    flex-wrap: wrap;
  }

  .meta-sep { opacity: 0.4; }

  .post-divider {
    height: 1px;
    background: var(--color-border);
    margin-bottom: 2.5rem;
  }

  .post-body {
    color: var(--color-text);
    font-size: 1.0625rem;
    line-height: 1.8;
  }

  /* ── Prose paragraphs ── */
  .post-body :global(p) {
    margin-block: 1.25em;
  }

  /* ── Prose headings ── */
  .post-body :global(h2),
  .post-body :global(h3),
  .post-body :global(h4),
  .post-body :global(h5),
  .post-body :global(h6) {
    color: var(--color-heading);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin-top: 2em;
    margin-bottom: 0.5em;
    scroll-margin-top: 5rem;
  }

  .post-body :global(h2) {
    font-size: 1.625rem;
  }

  .post-body :global(h3) {
    font-size: 1.3rem;
  }

  .post-body :global(h4) {
    font-size: 1.125rem;
    letter-spacing: -0.01em;
  }

  .post-body :global(h5) {
    font-size: 1rem;
    letter-spacing: 0;
  }

  .post-body :global(h6) {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0;
  }

  .post-body :global(a) {
    color: var(--color-sage);
    text-decoration-color: var(--color-sage);
  }
  .post-body :global(a:hover) {
    color: var(--color-olive);
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--color-sage);
    padding-left: 1.25rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-inline: 0;
  }

  .post-body :global(pre) {
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    overflow-x: auto;
    padding: 1.25rem 1.5rem;
  }

  .post-body :global(code:not(pre code)) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.1rem 0.35rem;
    font-size: 0.875em;
    color: var(--color-sage);
  }

  .post-body :global(img) {
    border-radius: 0.75rem;
    width: 100%;
    height: auto;
  }

  /* ── Enlargeable images ── */
  .post-body :global(.img-enlarge-wrap) {
    display: block;
    position: relative;
    cursor: zoom-in;
    border-radius: 0.75rem;
    overflow: hidden;
    /* Subtle border so the hint badge has a backdrop to sit against */
    outline: 1px solid transparent;
    transition: outline-color 0.2s ease, box-shadow 0.2s ease;
  }
  .post-body :global(.img-enlarge-wrap:hover) {
    outline-color: color-mix(in srgb, var(--color-sage) 35%, transparent);
    box-shadow: 0 4px 20px color-mix(in srgb, var(--color-charcoal) 12%, transparent);
  }
  .post-body :global(.img-enlarge-wrap img) {
    display: block;
    transition: opacity 0.2s ease;
  }
  .post-body :global(.img-enlarge-wrap:hover img) {
    opacity: 0.92;
  }

  /* "Click to enlarge" badge */
  .post-body :global(.img-enlarge-hint) {
    position: absolute;
    bottom: 0.6rem;
    right: 0.7rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #fff;
    background: color-mix(in srgb, var(--color-charcoal) 70%, transparent);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    padding: 0.25rem 0.5rem 0.25rem 0.4rem;
    border-radius: 100px;
    pointer-events: none;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    user-select: none;
  }
  .post-body :global(.img-enlarge-wrap:hover .img-enlarge-hint) {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Lightbox dialog ── */
  #img-lightbox {
    /* Reset browser dialog defaults */
    border: none;
    padding: 0;
    background: transparent;
    width: 100dvw;
    max-width: 100dvw;
    height: 100dvh;
    max-height: 100dvh;
    overflow: hidden;
  }

  /* Only display as flex when the dialog is actually open.
     Without this guard the author's display:flex overrides the browser's
     built-in display:none for closed <dialog> elements, making the
     100dvh-tall dialog sit in the document flow even when closed and
     creating a large blank scrollable area below the footer. */
  #img-lightbox[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Backdrop */
  #img-lightbox::backdrop {
    background: color-mix(in srgb, var(--color-charcoal) 88%, transparent);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  /* Fade/scale animations (open → closed driven by JS class toggling) */
  #img-lightbox[open] {
    animation: lightbox-in 0.22s ease both;
  }
  @keyframes lightbox-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes lightbox-out {
    from { opacity: 1; }
    to   { opacity: 0; }
  }
  #img-lightbox.is-closing {
    animation: lightbox-out 0.18s ease both;
  }

  /* Inner wrapper — contains the image + close button */
  .lightbox-inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    max-width: 95dvw;
    max-height: 95dvh;
  }

  #lightbox-img {
    display: block;
    max-width: 100%;
    max-height: 90dvh;
    width: auto;
    height: auto;
    border-radius: 0.75rem;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.5);
    object-fit: contain;
    cursor: zoom-out;
    animation: img-scale-in 0.22s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  @keyframes img-scale-in {
    from { transform: scale(0.94); opacity: 0; }
    to   { transform: scale(1);    opacity: 1; }
  }

  #lightbox-close {
    position: absolute;
    top: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    background: color-mix(in srgb, var(--color-charcoal) 70%, transparent);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: 1px solid color-mix(in srgb, #fff 20%, transparent);
    border-radius: 50%;
    color: #fff;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease;
    /* Keep it on top of the image */
    z-index: 1;
  }
  #lightbox-close:hover {
    background: color-mix(in srgb, var(--color-sage) 70%, transparent);
    border-color: var(--color-sage);
  }

  /* Respect reduced-motion preferences */
  @media (prefers-reduced-motion: reduce) {
    #img-lightbox[open],
    #img-lightbox.is-closing,
    #lightbox-img {
      animation: none;
    }
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-block: 2.5rem;
  }

  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .back-link-bottom {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .back-link-bottom:hover { color: var(--color-sage); }
</style>

<!-- Lightbox dialog (shared for all enlargeable images on the page) -->
<dialog id="img-lightbox" aria-label="Enlarged image" aria-modal="true">
  <div class="lightbox-inner">
    <img id="lightbox-img" src="" alt="" />
    <button id="lightbox-close" aria-label="Close enlarged image">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>
</dialog>

<script>
  // ── Wrap each post-body image in a clickable enlarge wrapper ──────────────
  const postBody = document.querySelector('.post-body');
  if (postBody) {
    postBody.querySelectorAll<HTMLImageElement>('img').forEach((img) => {
      // Skip already-wrapped images (e.g. on HMR re-runs)
      if (img.closest('.img-enlarge-wrap')) return;

      const wrap = document.createElement('span');
      wrap.className = 'img-enlarge-wrap';
      wrap.setAttribute('role', 'button');
      wrap.setAttribute('tabindex', '0');
      wrap.setAttribute('aria-label', `Enlarge image${img.alt ? ': ' + img.alt : ''}`);

      const hint = document.createElement('span');
      hint.className = 'img-enlarge-hint';
      // Zoom-in icon SVG + label
      hint.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35M11 8v6M8 11h6"/></svg>
        Click to enlarge
      `;

      img.parentNode!.insertBefore(wrap, img);
      wrap.appendChild(img);
      wrap.appendChild(hint);
    });
  }

  // ── Lightbox logic ────────────────────────────────────────────────────────
  const dialog    = document.getElementById('img-lightbox') as HTMLDialogElement | null;
  const lbImg     = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const closeBtn  = document.getElementById('lightbox-close');

  if (!dialog || !lbImg || !closeBtn) {
    // Safety: bail if elements are missing
  } else {
    function openLightbox(src: string, alt: string) {
      lbImg!.src = src;
      lbImg!.alt = alt;
      dialog!.classList.remove('is-closing');
      dialog!.showModal();
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      dialog!.classList.add('is-closing');
      // Wait for the closing animation before actually closing
      dialog!.addEventListener('animationend', () => {
        dialog!.close();
        dialog!.classList.remove('is-closing');
        document.body.style.overflow = '';
        lbImg!.src = '';
      }, { once: true });
    }

    // Open on image-wrap click or keyboard activation
    document.addEventListener('click', (e) => {
      const wrap = (e.target as Element).closest<HTMLElement>('.img-enlarge-wrap');
      if (!wrap) return;
      const img = wrap.querySelector<HTMLImageElement>('img');
      if (img) openLightbox(img.src, img.alt);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        const wrap = (e.target as Element).closest<HTMLElement>('.img-enlarge-wrap');
        if (wrap) {
          e.preventDefault();
          const img = wrap.querySelector<HTMLImageElement>('img');
          if (img) openLightbox(img.src, img.alt);
        }
      }
    });

    // Close via button
    closeBtn.addEventListener('click', closeLightbox);

    // Close via backdrop click (click lands on <dialog>, not .lightbox-inner)
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) closeLightbox();
    });

    // Close via Escape (browser fires 'cancel' on dialog for Escape)
    dialog.addEventListener('cancel', (e) => {
      e.preventDefault(); // prevent instant close; let animation play
      closeLightbox();
    });
  }
</script>
