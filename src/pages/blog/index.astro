---
import { BLOG_ENABLED } from '../../config';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

if (!BLOG_ENABLED) return Astro.redirect('/404', 404);

const allPosts = await getCollection('blog', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
);

const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Blog"
  description="Thoughts on software engineering, system design, cloud infrastructure, and the occasional tangent."
>
  <div class="blog-wrapper">
    <div class="container">
      <header class="blog-header">
        <p class="section-label">Blog</p>
        <h1 class="blog-title">Writing</h1>
        <p class="blog-sub">
          Thoughts on software engineering, system design, and whatever else is on my mind.
        </p>
      </header>

      {posts.length === 0 ? (
        <div class="empty-state">
          <p>No posts yet. Check back soon.</p>
        </div>
      ) : (
        <ul class="post-list" role="list">
          {posts.map(post => {
            const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            });
            const words = post.body?.split(/\s+/).length ?? 0;
            const readingTime = Math.max(1, Math.round(words / 200));

            return (
              <li class="post-item">
                <a href={`/blog/${post.id}/`} class="post-card">
                  <div class="post-card-meta">
                    <time datetime={post.data.pubDate.toISOString()} class="post-date">
                      {formattedDate}
                    </time>
                    <span class="post-reading-time">{readingTime} min read</span>
                  </div>
                  <h2 class="post-card-title">{post.data.title}</h2>
                  <p class="post-card-desc">{post.data.description}</p>
                  {post.data.tags.length > 0 && (
                    <div class="post-card-tags" aria-label="Tags">
                      {post.data.tags.map(tag => (
                        <span class="tag">{tag}</span>
                      ))}
                    </div>
                  )}
                  <span class="post-card-read">
                    Read post
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="m9 18 6-6-6-6"/>
                    </svg>
                  </span>
                </a>
              </li>
            );
          })}
        </ul>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .blog-wrapper {
    background: var(--color-bg);
    min-height: 100svh;
    padding-top: 6rem;
    padding-bottom: 5rem;
    transition: background 0.3s ease;
  }

  .blog-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .section-label {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-sage);
    margin: 0 0 0.5rem;
  }

  .blog-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--color-heading);
    margin: 0 0 0.75rem;
    letter-spacing: -0.03em;
  }

  .blog-sub {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
    max-width: 52ch;
  }

  .empty-state {
    padding: 4rem 0;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-card {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 1.75rem;
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .post-card:hover {
    border-color: var(--color-sage);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px color-mix(in srgb, var(--color-sage) 10%, transparent);
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .post-date {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .post-reading-time {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    padding-left: 0.75rem;
    border-left: 1px solid var(--color-border);
  }

  .post-card-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-heading);
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
    line-height: 1.3;
    transition: color 0.2s ease;
  }

  .post-card:hover .post-card-title {
    color: var(--color-sage);
  }

  .post-card-desc {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0 0 1rem;
  }

  .post-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .tag {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-sage);
    background: color-mix(in srgb, var(--color-sage) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-sage) 25%, transparent);
    padding: 0.15rem 0.55rem;
    border-radius: 100px;
  }

  .post-card-read {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-sage);
    transition: gap 0.2s ease;
  }

  .post-card:hover .post-card-read {
    gap: 0.5rem;
  }
</style>
