---
import { BLOG_ENABLED } from '../config';

const year = new Date().getFullYear();

const socials = [
  {
    label: 'GitHub',
    href: 'https://github.com/crallen',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>`,
  },

  {
    label: 'X (Twitter)',
    href: 'https://twitter.com/crallen',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
  {
    label: 'Facebook',
    href: 'https://facebook.com/crallend',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
  },
];
---

<footer>
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="brand-link">chrisallen.dev</a>
      <p class="tagline">Software Architect &amp; Platform Engineer</p>
    </div>

    <div class="footer-socials">
      {socials.map(s => (
        <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label} class="social-link" set:html={s.icon} />
      ))}
    </div>

    <div class="footer-copy">
      <p>
        &copy; {year} Christopher R. Allen
        {BLOG_ENABLED && <>&nbsp;·&nbsp;<a href="/rss.xml" class="rss-link">RSS</a></>}
      </p>
      <p class="disclaimer">
        All trademarks and logos are the property of their respective owners.
      </p>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--color-section-dark-bg);
    color: var(--color-section-dark-text);
    padding-block: 3rem;
    margin-top: 0;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
    text-align: center;
  }

  @media (min-width: 768px) {
    .footer-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
      text-align: left;
    }
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .brand-link {
    font-weight: 700;
    font-size: 1rem;
    color: inherit;
    text-decoration: none;
    letter-spacing: -0.02em;
    transition: color 0.2s ease;
  }
  .brand-link:hover { color: var(--color-sage); }

  .tagline {
    font-size: 0.85rem;
    color: var(--color-section-dark-muted);
    margin: 0;
    max-width: 28ch;
  }

  .footer-socials {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid color-mix(in srgb, #F5F0EB 20%, transparent);
    border-radius: 0.5rem;
    color: color-mix(in srgb, #F5F0EB 60%, transparent);
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .social-link:hover {
    color: #F5F0EB;
    border-color: var(--color-sage);
    background: color-mix(in srgb, var(--color-sage) 20%, transparent);
  }

  .footer-copy {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.8rem;
    color: color-mix(in srgb, #F5F0EB 45%, transparent);
  }

  .footer-copy p { margin: 0; }

  .rss-link {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }
  .rss-link:hover {
    color: var(--color-sage);
  }

  .disclaimer {
    max-width: 36ch;
  }
</style>
