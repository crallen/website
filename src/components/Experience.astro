---
const companies = [
  {
    key: '8am',
    name: '8am',
    href: 'https://8am.com',
    logo: '/images/logos/8am.png',
  },
  {
    key: 'fsg',
    name: 'FSG',
    href: 'https://fsg.com',
    logo: '/images/logos/fsg.svg',
  },
  {
    key: 'ufcu',
    name: 'UFCU',
    href: 'https://ufcu.org',
    logo: '/images/logos/ufcu.svg',
  },
  {
    key: 'capitalone',
    name: 'Capital One',
    href: 'https://capitalone.com',
    logo: '/images/logos/capitalone.svg',
  },

];
---

<section id="experience" aria-labelledby="experience-heading">
  <div class="container experience-inner">
    <div class="experience-header">
      <p class="section-label">Experience</p>
      <h2 id="experience-heading" class="experience-title">
        Companies I've worked with.
      </h2>
      <p class="experience-sub">
        I've had the opportunity to build software for great organizations across
        fintech, IoT, credit unions, and e-commerce&mdash;from early-stage startups
        to large enterprise.
      </p>
    </div>

    <div class="company-grid">
      {companies.map(company => (
        <a
          href={company.href}
          target="_blank"
          rel="noopener noreferrer"
          class="company-card"
          aria-label={`${company.name} (opens in new tab)`}
        >
          <img
            src={company.logo}
            alt={company.name}
            class="company-logo"
            loading="lazy"
            decoding="async"
          />
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  #experience {
    background: var(--color-olive);
    padding-block: 5rem;
    transition: background 0.3s ease;
  }

  .experience-inner {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .section-label {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-sage);
    margin: 0 0 0.5rem;
  }

  .experience-title {
    font-size: clamp(1.6rem, 3.5vw, 2.25rem);
    font-weight: 700;
    color: #F5F0EB;
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }

  .experience-sub {
    font-size: 1rem;
    line-height: 1.7;
    color: color-mix(in srgb, #F5F0EB 70%, transparent);
    margin: 0;
    max-width: 55ch;
  }

  .company-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .company-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (min-width: 1024px) {
    .company-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .company-card {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #F5F0EB;
    border: 1px solid color-mix(in srgb, #F5F0EB 40%, transparent);
    border-radius: 1rem;
    padding: 1.5rem;
    aspect-ratio: 3 / 2;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .company-card:hover {
    border-color: #F5F0EB;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px color-mix(in srgb, #000 25%, transparent);
  }

  .company-logo {
    width: 100%;
    max-width: 140px;
    height: auto;
    max-height: 60px;
    object-fit: contain;
  }
</style>
