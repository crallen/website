---
---

<section id="contact" aria-labelledby="contact-heading">
  <div class="container contact-inner">
    <div class="contact-header">
      <p class="section-label">Get In Touch</p>
      <h2 id="contact-heading" class="contact-title">Let's talk.</h2>
      <p class="contact-sub">
        Have a question, a project, or just want to say hello? Fill out the form
        or email me directly.
      </p>
      <a href="mailto:chris@chrisallen.dev" class="contact-email">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect width="20" height="16" x="2" y="4" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
        chris@chrisallen.dev
      </a>
    </div>

    <form
      name="contact"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      action="/contact-success"
      class="contact-form"
    >
      <!-- Netlify hidden input -->
      <input type="hidden" name="form-name" value="contact" />

      <!-- Honeypot field (hidden from humans) -->
      <p class="sr-only" aria-hidden="true">
        <label>Don't fill this out: <input name="bot-field" /></label>
      </p>

      <div class="form-row">
        <div class="form-group">
          <label for="contact-name" class="form-label">Name</label>
          <input
            id="contact-name"
            type="text"
            name="name"
            class="form-input"
            placeholder="Your name"
            required
            autocomplete="name"
          />
        </div>
        <div class="form-group">
          <label for="contact-email" class="form-label">Email</label>
          <input
            id="contact-email"
            type="email"
            name="email"
            class="form-input"
            placeholder="you@example.com"
            required
            autocomplete="email"
          />
        </div>
      </div>

      <div class="form-group">
        <label for="contact-message" class="form-label">Message</label>
        <textarea
          id="contact-message"
          name="message"
          class="form-input form-textarea"
          placeholder="What's on your mind?"
          rows="5"
          required
        ></textarea>
      </div>

      <button type="submit" class="btn-submit">
        Send Message
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m22 2-7 20-4-9-9-4Z"/>
          <path d="M22 2 11 13"/>
        </svg>
      </button>
    </form>
  </div>
</section>

<style>
  #contact {
    background: var(--color-surface);
    padding-block: 5rem;
    transition: background 0.3s ease;
  }

  .contact-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .contact-inner {
      grid-template-columns: 1fr 1.5fr;
      align-items: start;
    }
  }

  .section-label {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-sage);
    margin: 0 0 0.5rem;
  }

  .contact-title {
    font-size: clamp(1.6rem, 3.5vw, 2.25rem);
    font-weight: 700;
    color: var(--color-heading);
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }

  .contact-sub {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin: 0 0 1rem;
  }

  .contact-email {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-sage);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .contact-email:hover {
    color: var(--color-olive);
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 480px) {
    .form-row { grid-template-columns: 1fr 1fr; }
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-heading);
    letter-spacing: 0.01em;
  }

  .form-input {
    width: 100%;
    padding: 0.7rem 0.9rem;
    border: 1.5px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    outline: none;
  }

  .form-input::placeholder {
    color: var(--color-text-muted);
  }

  .form-input:focus,
  .form-input:focus-visible {
    border-color: var(--color-sage);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-sage) 15%, transparent);
  }

  .form-textarea {
    resize: vertical;
    min-height: 140px;
  }

  .btn-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.8rem 2rem;
    background: var(--color-sage);
    color: #F5F0EB;
    border: none;
    border-radius: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
    align-self: flex-start;
  }

  .btn-submit:hover {
    background: var(--color-olive);
    transform: translateY(-1px);
  }

  .btn-submit:active {
    transform: translateY(0);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
