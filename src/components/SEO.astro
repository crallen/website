---
import { BLOG_ENABLED } from '../config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  type?: 'website' | 'article';
  pubDate?: Date;
  noindex?: boolean;
}

const {
  title = 'Chris Allen',
  description = 'Software Architect & Platform Engineer with more than 20 years of experience in system design, backend development, and cloud infrastructure.',
  image = '/images/bg.jpg',
  type = 'website',
  pubDate,
  noindex = false,
} = Astro.props;

const siteTitle = title === 'Chris Allen'
  ? 'Chris Allen — Software Architect & Platform Engineer'
  : `${title} · Chris Allen`;
const canonicalURL = Astro.props.canonicalURL ?? new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;
---

<!-- Primary meta -->
<title>{siteTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={siteTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:site_name" content="Chris Allen" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@crallen" />
<meta name="twitter:title" content={siteTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

{type === 'article' && pubDate && (
  <meta property="article:published_time" content={pubDate.toISOString()} />
)}

<!-- RSS (only when blog is enabled) -->
{BLOG_ENABLED && (
  <link rel="alternate" type="application/rss+xml" title="Chris Allen Blog" href="/rss.xml" />
)}
